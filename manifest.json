<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <meta name="theme-color" content="#17251b">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-title" content="78计划">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <link rel="manifest" href="manifest.json">
  <title>78计划</title>
  <style>
    :root {
      --bg: #f4f2ec;
      --surface: #fffdf8;
      --surface-2: #f8f5ee;
      --ink: #17251b;
      --muted: #687064;
      --line: #ded8ca;
      --brand: #2f6f4e;
      --brand-2: #173f2d;
      --accent: #d88a3d;
      --accent-soft: #fff0df;
      --good: #2f7d57;
      --danger: #b85742;
      --shadow: 0 14px 38px rgba(23, 37, 27, 0.1);
      --radius: 8px;
      --nav-h: 74px;
    }

    * {
      box-sizing: border-box;
      -webkit-tap-highlight-color: transparent;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      margin: 0;
      min-height: 100vh;
      color: var(--ink);
      background:
        radial-gradient(circle at 12% -8%, rgba(216, 138, 61, 0.16), transparent 30%),
        linear-gradient(180deg, #f8f5ee 0%, var(--bg) 48%, #efeadf 100%);
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Microsoft YaHei", sans-serif;
    }

    button, input, select, textarea {
      font: inherit;
    }

    button {
      border: 0;
      cursor: pointer;
    }

    .app {
      width: min(100%, 520px);
      min-height: 100vh;
      margin: 0 auto;
      padding: max(16px, env(safe-area-inset-top)) 14px calc(var(--nav-h) + env(safe-area-inset-bottom) + 16px);
    }

    .topbar {
      position: sticky;
      top: 0;
      z-index: 20;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin: -16px -14px 12px;
      padding: max(16px, env(safe-area-inset-top)) 14px 12px;
      background: rgba(244, 242, 236, 0.92);
      backdrop-filter: blur(14px);
      border-bottom: 1px solid rgba(222, 216, 202, 0.6);
    }

    .brand h1 {
      margin: 0;
      font-size: 22px;
      line-height: 1.1;
      letter-spacing: 0;
    }

    .brand p {
      margin: 4px 0 0;
      color: var(--muted);
      font-size: 12px;
    }

    .pill {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 32px;
      padding: 7px 10px;
      border-radius: 999px;
      background: var(--surface);
      border: 1px solid var(--line);
      color: var(--muted);
      font-size: 12px;
      white-space: nowrap;
    }

    .screen {
      display: none;
      animation: rise 180ms ease-out;
    }

    .screen.active {
      display: block;
    }

    @keyframes rise {
      from { opacity: 0; transform: translateY(8px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .hero {
      padding: 16px;
      border-radius: var(--radius);
      color: #fff;
      background: linear-gradient(145deg, #173f2d 0%, #2f6f4e 58%, #5c8c57 100%);
      box-shadow: var(--shadow);
    }

    .hero-head {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      align-items: flex-start;
    }

    .hero small {
      display: block;
      opacity: 0.75;
      font-size: 12px;
    }

    .hero strong {
      display: block;
      margin-top: 5px;
      font-size: clamp(38px, 13vw, 60px);
      line-height: 0.95;
      letter-spacing: 0;
    }

    .hero .unit {
      font-size: 14px;
      opacity: 0.78;
      margin-left: 4px;
    }

    .quest-card {
      margin-top: 14px;
      padding: 12px;
      border-radius: var(--radius);
      background: rgba(255, 255, 255, 0.12);
      border: 1px solid rgba(255, 255, 255, 0.18);
    }

    .quest-top {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      font-size: 13px;
      margin-bottom: 8px;
    }

    .quest-bar,
    .bar {
      height: 10px;
      overflow: hidden;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.2);
    }

    .quest-bar i,
    .bar i {
      display: block;
      height: 100%;
      width: 0;
      border-radius: inherit;
      background: #fff;
      transition: width 180ms ease;
    }

    .quick-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      margin-top: 12px;
    }

    .quick-btn {
      min-height: 48px;
      border-radius: var(--radius);
      background: var(--surface);
      color: var(--ink);
      font-weight: 750;
      box-shadow: 0 8px 20px rgba(23, 37, 27, 0.08);
    }

    .quick-btn.primary {
      color: #fff;
      background: var(--accent);
    }

    .section-title {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin: 18px 0 10px;
    }

    .section-title h2 {
      margin: 0;
      font-size: 18px;
      line-height: 1.2;
    }

    .section-title p {
      margin: 3px 0 0;
      color: var(--muted);
      font-size: 12px;
    }

    .card {
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: var(--surface);
      box-shadow: var(--shadow);
      padding: 14px;
    }

    .flat-card {
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: var(--surface);
      padding: 12px;
    }

    .macro-grid,
    .stat-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
    }

    .macro {
      padding: 12px;
      border-radius: var(--radius);
      background: var(--surface);
      border: 1px solid var(--line);
    }

    .macro span,
    .stat span,
    label span {
      display: block;
      color: var(--muted);
      font-size: 12px;
      line-height: 1.35;
    }

    .macro strong,
    .stat strong {
      display: block;
      margin-top: 5px;
      font-size: 20px;
      line-height: 1.1;
    }

    .macro .bar {
      margin-top: 10px;
      background: #ece7dc;
    }

    .macro .bar i {
      background: var(--brand);
    }

    .meal-list {
      display: grid;
      gap: 10px;
    }

    .meal-row {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 10px;
      align-items: center;
      padding: 12px;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: var(--surface);
    }

    .meal-row h3 {
      margin: 0;
      font-size: 16px;
    }

    .meal-row p {
      margin: 4px 0 0;
      color: var(--muted);
      font-size: 12px;
    }

    .meal-score {
      min-width: 74px;
      text-align: right;
      font-weight: 760;
      color: var(--brand-2);
    }

    .tabs {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
      padding: 5px;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: var(--surface-2);
    }

    .tabs button {
      min-height: 42px;
      border-radius: 7px;
      color: var(--muted);
      background: transparent;
      font-weight: 750;
    }

    .tabs button.active {
      color: #fff;
      background: var(--brand);
      box-shadow: 0 8px 18px rgba(47, 111, 78, 0.22);
    }

    .form-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
    }

    label {
      display: grid;
      gap: 7px;
      color: var(--muted);
      font-size: 12px;
    }

    .full {
      grid-column: 1 / -1;
    }

    input, select, textarea {
      width: 100%;
      min-height: 44px;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      padding: 10px 11px;
      color: var(--ink);
      background: #fff;
      outline: none;
      font-size: 16px;
    }

    textarea {
      min-height: 82px;
      resize: vertical;
    }

    input:focus, select:focus, textarea:focus {
      border-color: var(--brand);
      box-shadow: 0 0 0 3px rgba(47, 111, 78, 0.14);
    }

    input:disabled {
      color: #8d948b;
      background: #f1eee6;
    }

    .actions {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      margin-top: 12px;
    }

    .btn {
      min-height: 46px;
      border-radius: var(--radius);
      padding: 10px 12px;
      color: #fff;
      background: var(--brand);
      font-weight: 800;
    }

    .btn.secondary {
      color: var(--brand-2);
      background: #e7efe6;
    }

    .btn.warn {
      color: var(--danger);
      background: #f9e6df;
    }

    .btn.full {
      grid-column: 1 / -1;
    }

    .hint {
      color: var(--brand-2);
      background: #e7efe6;
      border-radius: var(--radius);
      padding: 12px;
      font-size: 13px;
      line-height: 1.6;
    }

    .mini {
      color: var(--muted);
      font-size: 12px;
      line-height: 1.5;
    }

    .chart-wrap {
      overflow: hidden;
    }

    .chart {
      width: 100%;
      height: 260px;
      display: block;
    }

    .chart-label {
      fill: var(--muted);
      font-size: 12px;
    }

    .chart line,
    .chart path {
      vector-effect: non-scaling-stroke;
    }

    .history {
      display: grid;
      gap: 10px;
      max-height: 320px;
      overflow: auto;
    }

    .history-item {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 10px;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      padding: 12px;
      background: var(--surface);
    }

    .history-item strong {
      display: block;
    }

    .history-item p {
      margin: 4px 0 0;
      color: var(--muted);
      font-size: 12px;
      line-height: 1.45;
    }

    .empty {
      padding: 18px;
      text-align: center;
      color: var(--muted);
      border: 1px dashed var(--line);
      border-radius: var(--radius);
      background: var(--surface);
    }

    .bottom-nav {
      position: fixed;
      left: 50%;
      bottom: 0;
      z-index: 30;
      width: min(100%, 520px);
      transform: translateX(-50%);
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 6px;
      padding: 8px 12px calc(8px + env(safe-area-inset-bottom));
      background: rgba(255, 253, 248, 0.94);
      border-top: 1px solid rgba(222, 216, 202, 0.9);
      backdrop-filter: blur(16px);
      box-shadow: 0 -12px 34px rgba(23, 37, 27, 0.1);
    }

    .bottom-nav button {
      min-height: 48px;
      border-radius: var(--radius);
      background: transparent;
      color: var(--muted);
      font-size: 12px;
      font-weight: 760;
    }

    .bottom-nav button.active {
      color: #fff;
      background: var(--ink);
    }

    .toast {
      position: fixed;
      left: 50%;
      bottom: calc(var(--nav-h) + env(safe-area-inset-bottom) + 14px);
      z-index: 50;
      width: min(calc(100% - 28px), 492px);
      transform: translate(-50%, 14px);
      opacity: 0;
      pointer-events: none;
      transition: opacity 180ms ease, transform 180ms ease;
      border-radius: var(--radius);
      padding: 13px 14px;
      color: #fff;
      background: var(--ink);
      box-shadow: var(--shadow);
      font-size: 14px;
      line-height: 1.45;
    }

    .toast.show {
      opacity: 1;
      transform: translate(-50%, 0);
    }

    .install {
      display: none;
    }

    @media (min-width: 840px) {
      .app {
        width: min(100% - 40px, 1040px);
        padding-bottom: 32px;
      }

      .desktop-grid {
        display: grid;
        grid-template-columns: 1.05fr 0.95fr;
        gap: 14px;
        align-items: start;
      }

      .bottom-nav {
        top: 16px;
        bottom: auto;
        left: auto;
        right: 24px;
        width: 360px;
        transform: none;
        border: 1px solid var(--line);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
      }
    }

    @media (max-width: 380px) {
      .macro-grid,
      .stat-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
<body>
  <div class="app">
    <header class="topbar">
      <div class="brand">
        <h1>78计划</h1>
        <p>饮食记录、体重趋势和每日任务</p>
      </div>
      <button class="pill install" id="installBtn" type="button">添加到手机</button>
      <span class="pill" id="todayPill"></span>
    </header>

    <section class="screen active" data-screen="home">
      <div class="desktop-grid">
        <div>
          <div class="hero">
            <div class="hero-head">
              <div>
                <small>今天还可以吃</small>
                <strong><span id="remainingCalories">0</span><span class="unit">kcal</span></strong>
              </div>
              <span class="pill" id="streakPill">连续 0 天</span>
            </div>
            <div class="quest-card">
              <div class="quest-top">
                <span id="questTitle">今日任务</span>
                <b id="questScore">0 / 100</b>
              </div>
              <div class="quest-bar"><i id="questBar"></i></div>
            </div>
          </div>

          <div class="quick-grid">
            <button class="quick-btn primary" type="button" data-go="log">记录一餐</button>
            <button class="quick-btn" type="button" data-go="trend">看 7 日变化</button>
          </div>

          <div class="section-title">
            <div>
              <h2>碳蛋脂进度</h2>
              <p id="macroModeLabel">532 模式</p>
            </div>
          </div>
          <div class="macro-grid" id="macroGrid"></div>
        </div>

        <div>
          <div class="section-title">
            <div>
              <h2>今日三餐</h2>
              <p>保存一餐就会更新任务分</p>
            </div>
          </div>
          <div class="meal-list" id="mealList"></div>

          <div class="section-title">
            <div>
              <h2>即时建议</h2>
              <p>按剩余缺口给你补齐方向</p>
            </div>
          </div>
          <div class="hint" id="adviceBox"></div>
        </div>
      </div>
    </section>

    <section class="screen" data-screen="log">
      <div class="section-title">
        <div>
          <h2>记录今天</h2>
          <p>先选餐别，再填这餐的碳蛋脂</p>
        </div>
      </div>

      <div class="card">
        <div class="form-grid">
          <label><span>日期</span><input id="logDate" type="date"></label>
          <label><span>晨重 kg</span><input id="bodyWeight" type="number" min="30" max="250" step="0.1" placeholder="80.0"></label>
        </div>
        <div class="tabs" style="margin-top:12px;">
          <button type="button" class="active" data-meal-tab="breakfast">早餐</button>
          <button type="button" data-meal-tab="lunch">午餐</button>
          <button type="button" data-meal-tab="dinner">晚餐</button>
        </div>
        <div class="form-grid" style="margin-top:12px;">
          <label><span>热量 kcal，可选</span><input id="mealCalories" type="number" min="0" step="1" placeholder="留空则按碳蛋脂估算"></label>
          <label><span>碳水 g</span><input id="mealCarbs" type="number" min="0" step="0.1" value="0"></label>
          <label><span>蛋白 g</span><input id="mealProtein" type="number" min="0" step="0.1" value="0"></label>
          <label><span>脂肪 g</span><input id="mealFat" type="number" min="0" step="0.1" value="0"></label>
          <label class="full"><span>备注</span><textarea id="note" placeholder="比如：午餐米饭、牛肉、青菜。"></textarea></label>
        </div>
        <div class="actions">
          <button class="btn" id="saveLog" type="button">保存并结算</button>
          <button class="btn secondary" id="copyMeal" type="button">复制到下一餐</button>
          <button class="btn warn full" id="clearMeal" type="button">清空当前餐</button>
        </div>
      </div>

      <div class="section-title">
        <div>
          <h2>今日合计</h2>
          <p>热量优先采用你填写的 kcal，没填则自动估算</p>
        </div>
      </div>
      <div class="stat-grid" id="todayTotals"></div>
    </section>

    <section class="screen" data-screen="trend">
      <div class="section-title">
        <div>
          <h2>体重趋势</h2>
          <p>重点看 7 日均重，不被单日水分带偏</p>
        </div>
      </div>
      <div class="stat-grid" id="trendSummary"></div>
      <div class="card chart-wrap" style="margin-top:12px;">
        <svg id="weightChart" class="chart" viewBox="0 0 920 280" role="img" aria-label="体重变化曲线"></svg>
      </div>

      <div class="section-title">
        <div>
          <h2>历史记录</h2>
          <p>点击载入某天继续修改</p>
        </div>
      </div>
      <div class="history" id="history"></div>
    </section>

    <section class="screen" data-screen="profile">
      <div class="section-title">
        <div>
          <h2>我的目标</h2>
          <p>默认按你本人和 532 比例计算</p>
        </div>
      </div>
      <div class="card">
        <div class="form-grid">
          <label><span>性别</span><select id="sex"><option value="male">男</option><option value="female">女</option></select></label>
          <label><span>年龄</span><input id="age" type="number" min="12" max="90"></label>
          <label><span>身高 cm</span><input id="height" type="number" min="120" max="230"></label>
          <label><span>体重 kg</span><input id="weight" type="number" min="30" max="250" step="0.1"></label>
          <label><span>活动量</span><select id="activity">
            <option value="1.2">久坐，很少运动</option>
            <option value="1.375">轻量活动，每周 1-3 次</option>
            <option value="1.55">中等活动，每周 3-5 次</option>
            <option value="1.6">力量训练 4-6 天，少有氧</option>
            <option value="1.725">高活动，每周 6-7 次</option>
            <option value="1.9">体力劳动或高强度训练</option>
          </select></label>
          <label><span>目标</span><select id="goal">
            <option value="loss">减脂</option>
            <option value="slow-loss">温和减脂</option>
            <option value="maintain">维持</option>
            <option value="gain">增肌</option>
          </select></label>
          <label class="full"><span>碳蛋脂模式</span><select id="macroMode">
            <option value="532">532：热量按碳水 50% / 蛋白 30% / 脂肪 20%</option>
            <option value="auto">自定义保蛋白：先按 g/kg 定蛋白和脂肪，剩余给碳水</option>
          </select></label>
          <label><span>蛋白目标 g/kg</span><input id="proteinRate" type="number" min="1" max="2.8" step="0.1"></label>
          <label><span>脂肪目标 g/kg</span><input id="fatRate" type="number" min="0.4" max="1.3" step="0.1"></label>
        </div>
        <div class="actions">
          <button class="btn" id="saveProfile" type="button">保存目标</button>
          <button class="btn secondary" id="resetProfile" type="button">恢复默认</button>
        </div>
      </div>

      <div class="section-title">
        <div>
          <h2>今日目标</h2>
          <p id="profileHint"></p>
        </div>
      </div>
      <div class="stat-grid" id="targetSummary"></div>

      <div class="section-title">
        <div>
          <h2>数据迁移</h2>
          <p>换手机或部署到网页后可以导出导入</p>
        </div>
      </div>
      <div class="card">
        <div class="actions">
          <button class="btn secondary" id="exportData" type="button">导出数据</button>
          <button class="btn secondary" id="importData" type="button">导入数据</button>
        </div>
        <textarea id="dataBox" placeholder="导出的数据会显示在这里；导入时把数据粘贴进来再点导入。"></textarea>
      </div>
    </section>
  </div>

  <nav class="bottom-nav" aria-label="主导航">
    <button class="active" type="button" data-nav="home">首页</button>
    <button type="button" data-nav="log">记录</button>
    <button type="button" data-nav="trend">趋势</button>
    <button type="button" data-nav="profile">我的</button>
  </nav>

  <div class="toast" id="toast"></div>

  <script>
    const storeKey = "diet-tool-v1";
    const todayISO = new Date().toISOString().slice(0, 10);
    const defaultProfile = {
      sex: "male",
      age: 23,
      height: 169,
      weight: 80,
      activity: "1.6",
      goal: "slow-loss",
      proteinRate: 2,
      fatRate: 0.7,
      macroMode: "532"
    };
    const mealKeys = ["breakfast", "lunch", "dinner"];
    const mealLabels = { breakfast: "早餐", lunch: "午餐", dinner: "晚餐" };
    const profileFields = ["sex", "age", "height", "weight", "activity", "goal", "proteinRate", "fatRate", "macroMode"];

    let activeMeal = "breakfast";
    let deferredInstallPrompt = null;
    const state = loadState();

    normalizeState();
    applyProfile(state.profile);
    document.getElementById("logDate").value = todayISO;
    hydrateLog(todayISO);
    bindEvents();
    render();

    function bindEvents() {
      document.querySelectorAll("[data-nav], [data-go]").forEach((button) => {
        button.addEventListener("click", () => showScreen(button.dataset.nav || button.dataset.go));
      });
      document.querySelectorAll("[data-meal-tab]").forEach((button) => {
        button.addEventListener("click", () => {
          saveEditorToMeal();
          activeMeal = button.dataset.mealTab;
          renderMealTabs();
          loadMealEditor();
        });
      });

      document.getElementById("logDate").addEventListener("change", () => {
        hydrateLog(value("logDate") || todayISO);
        render();
      });
      ["bodyWeight", "note", "mealCalories", "mealCarbs", "mealProtein", "mealFat"].forEach((id) => {
        document.getElementById(id).addEventListener("input", () => {
          saveEditorToMeal();
          render();
        });
      });
      profileFields.forEach((id) => {
        document.getElementById(id).addEventListener("change", () => {
          state.profile = readProfile();
          persist();
          render();
        });
        document.getElementById(id).addEventListener("input", () => {
          state.profile = readProfile();
          persist();
          render();
        });
      });

      document.getElementById("saveLog").addEventListener("click", () => {
        saveEditorToMeal();
        const log = currentDraftLog();
        state.logs[log.date] = log;
        persist();
        hydrateLog(log.date);
        render();
        const score = scoreLog(log, calculateTargets(readProfile())).score;
        toast(`已保存。今日任务 ${score}/100，${score >= 80 ? "节奏很好" : "继续补齐缺口"}`);
      });

      document.getElementById("copyMeal").addEventListener("click", () => {
        saveEditorToMeal();
        const next = activeMeal === "breakfast" ? "lunch" : activeMeal === "lunch" ? "dinner" : "breakfast";
        const meals = getDraftMeals();
        meals[next] = { ...meals[activeMeal] };
        writeDraftMeals(meals);
        activeMeal = next;
        renderMealTabs();
        loadMealEditor();
        render();
        toast(`已复制到${mealLabels[next]}`);
      });

      document.getElementById("clearMeal").addEventListener("click", () => {
        writeMealEditor({ calories: 0, carbs: 0, protein: 0, fat: 0 });
        saveEditorToMeal();
        render();
      });

      document.getElementById("saveProfile").addEventListener("click", () => {
        state.profile = readProfile();
        persist();
        render();
        toast("目标已保存");
      });
      document.getElementById("resetProfile").addEventListener("click", () => {
        state.profile = { ...defaultProfile };
        applyProfile(state.profile);
        persist();
        render();
        toast("已恢复你的默认数据");
      });
      document.getElementById("exportData").addEventListener("click", () => {
        document.getElementById("dataBox").value = JSON.stringify(state, null, 2);
        toast("数据已导出到文本框");
      });
      document.getElementById("importData").addEventListener("click", () => {
        try {
          const next = JSON.parse(document.getElementById("dataBox").value);
          if (!next || !next.logs) throw new Error("bad data");
          state.profile = next.profile || defaultProfile;
          state.logs = next.logs || {};
          normalizeState();
          applyProfile(state.profile);
          persist();
          hydrateLog(value("logDate") || todayISO);
          render();
          toast("导入成功");
        } catch {
          toast("导入失败：请检查数据格式");
        }
      });

      window.addEventListener("beforeinstallprompt", (event) => {
        event.preventDefault();
        deferredInstallPrompt = event;
        document.getElementById("installBtn").style.display = "inline-flex";
      });
      document.getElementById("installBtn").addEventListener("click", async () => {
        if (!deferredInstallPrompt) return;
        deferredInstallPrompt.prompt();
        await deferredInstallPrompt.userChoice;
        deferredInstallPrompt = null;
        document.getElementById("installBtn").style.display = "none";
      });
      if ("serviceWorker" in navigator && location.protocol !== "file:") {
        navigator.serviceWorker.register("sw.js").catch(() => {});
      }
    }

    function loadState() {
      try {
        return JSON.parse(localStorage.getItem(storeKey)) || { profile: null, logs: {} };
      } catch {
        return { profile: null, logs: {} };
      }
    }

    function normalizeState() {
      if (!state.profile || isOldExampleProfile(state.profile)) state.profile = { ...defaultProfile };
      state.logs = state.logs || {};
      Object.keys(state.logs).forEach((date) => {
        const log = state.logs[date];
        if (!log.meals) log.meals = legacyMeals(log);
        const totals = totalMeals(log.meals);
        log.date = log.date || date;
        log.calories = totals.calories;
        log.carbs = totals.carbs;
        log.protein = totals.protein;
        log.fat = totals.fat;
      });
    }

    function persist() {
      localStorage.setItem(storeKey, JSON.stringify(state));
    }

    function showScreen(name) {
      document.querySelectorAll(".screen").forEach((screen) => {
        screen.classList.toggle("active", screen.dataset.screen === name);
      });
      document.querySelectorAll("[data-nav]").forEach((button) => {
        button.classList.toggle("active", button.dataset.nav === name);
      });
      window.scrollTo({ top: 0, behavior: "smooth" });
    }

    function applyProfile(profile) {
      profileFields.forEach((id) => {
        if (document.getElementById(id)) document.getElementById(id).value = profile[id];
      });
    }

    function readProfile() {
      return {
        sex: value("sex"),
        age: num("age"),
        height: num("height"),
        weight: num("weight"),
        activity: value("activity"),
        goal: value("goal"),
        proteinRate: num("proteinRate"),
        fatRate: num("fatRate"),
        macroMode: value("macroMode")
      };
    }

    function hydrateLog(date) {
      const log = state.logs[date] || blankLog(date);
      document.getElementById("logDate").value = date;
      document.getElementById("bodyWeight").value = log.bodyWeight || "";
      document.getElementById("note").value = log.note || "";
      writeDraftMeals(log.meals || legacyMeals(log));
      activeMeal = "breakfast";
      renderMealTabs();
      loadMealEditor();
    }

    function currentDraftLog() {
      saveEditorToMeal();
      const meals = getDraftMeals();
      const totals = totalMeals(meals);
      return {
        date: value("logDate") || todayISO,
        bodyWeight: num("bodyWeight"),
        note: value("note"),
        meals,
        calories: totals.calories,
        carbs: totals.carbs,
        protein: totals.protein,
        fat: totals.fat
      };
    }

    function blankLog(date) {
      return {
        date,
        bodyWeight: 0,
        note: "",
        meals: {
          breakfast: blankMeal(),
          lunch: blankMeal(),
          dinner: blankMeal()
        },
        calories: 0,
        carbs: 0,
        protein: 0,
        fat: 0
      };
    }

    function blankMeal() {
      return { calories: 0, carbs: 0, protein: 0, fat: 0 };
    }

    function legacyMeals(log) {
      return {
        breakfast: {
          calories: log.calories || 0,
          carbs: log.carbs || 0,
          protein: log.protein || 0,
          fat: log.fat || 0
        },
        lunch: blankMeal(),
        dinner: blankMeal()
      };
    }

    function writeDraftMeals(meals) {
      sessionStorage.setItem("diet-draft-meals", JSON.stringify(meals));
    }

    function getDraftMeals() {
      try {
        const meals = JSON.parse(sessionStorage.getItem("diet-draft-meals"));
        return {
          breakfast: meals?.breakfast || blankMeal(),
          lunch: meals?.lunch || blankMeal(),
          dinner: meals?.dinner || blankMeal()
        };
      } catch {
        return { breakfast: blankMeal(), lunch: blankMeal(), dinner: blankMeal() };
      }
    }

    function loadMealEditor() {
      const meals = getDraftMeals();
      writeMealEditor(meals[activeMeal] || blankMeal());
    }

    function writeMealEditor(meal) {
      document.getElementById("mealCalories").value = meal.calories || "";
      document.getElementById("mealCarbs").value = meal.carbs || 0;
      document.getElementById("mealProtein").value = meal.protein || 0;
      document.getElementById("mealFat").value = meal.fat || 0;
    }

    function saveEditorToMeal() {
      const meals = getDraftMeals();
      meals[activeMeal] = {
        calories: num("mealCalories"),
        carbs: num("mealCarbs"),
        protein: num("mealProtein"),
        fat: num("mealFat")
      };
      writeDraftMeals(meals);
    }

    function totalMeals(meals) {
      return mealKeys.reduce((total, key) => {
        const meal = meals[key] || blankMeal();
        total.carbs += meal.carbs || 0;
        total.protein += meal.protein || 0;
        total.fat += meal.fat || 0;
        total.calories += meal.calories || macroCalories(meal);
        return total;
      }, { calories: 0, carbs: 0, protein: 0, fat: 0 });
    }

    function render() {
      const profile = readProfile();
      const targets = calculateTargets(profile);
      const log = currentDraftLog();
      renderProfileMode(profile, targets);
      renderHome(targets, log);
      renderMealList(log);
      renderProgress(targets, log);
      renderAdvice(targets, log);
      renderTotals(log);
      renderTrend();
      renderHistory();
      renderMealTabs();
      document.getElementById("todayPill").textContent = formatDate(value("logDate") || todayISO);
    }

    function renderProfileMode(profile, targets) {
      const ratioMode = profile.macroMode === "532";
      document.getElementById("proteinRate").disabled = ratioMode;
      document.getElementById("fatRate").disabled = ratioMode;
      document.getElementById("macroModeLabel").textContent = ratioMode ? "532 比例分配" : "自定义保蛋白";
      document.getElementById("profileHint").textContent = ratioMode
        ? "532 模式下，g/kg 输入不会参与计算。"
        : "自定义模式会先锁蛋白和脂肪，再分配碳水。";
      const items = [
        ["热量", `${round(targets.calories)} kcal`],
        ["碳水", `${round(targets.carbs)} g`],
        ["蛋白", `${round(targets.protein)} g`],
        ["脂肪", `${round(targets.fat)} g`],
        ["维持", `${round(targets.maintenance)} kcal`],
        ["基础代谢", `${round(targets.bmr)} kcal`]
      ];
      document.getElementById("targetSummary").innerHTML = items.map(([label, val]) => stat(label, val)).join("");
    }

    function renderHome(targets, log) {
      const remaining = Math.max(0, targets.calories - log.calories);
      const score = scoreLog(log, targets);
      document.getElementById("remainingCalories").textContent = round(remaining);
      document.getElementById("questTitle").textContent = score.title;
      document.getElementById("questScore").textContent = `${score.score} / 100`;
      document.getElementById("questBar").style.width = `${score.score}%`;
      document.getElementById("streakPill").textContent = `连续 ${streakDays()} 天`;
    }

    function renderProgress(targets, log) {
      const macros = [
        ["碳水", log.carbs, targets.carbs],
        ["蛋白", log.protein, targets.protein],
        ["脂肪", log.fat, targets.fat]
      ];
      document.getElementById("macroGrid").innerHTML = macros.map(([label, eaten, target]) => {
        const pct = target ? Math.min(130, eaten / target * 100) : 0;
        return `
          <div class="macro">
            <span>${label}</span>
            <strong>${round(eaten)} / ${round(target)}g</strong>
            <div class="bar"><i style="width:${pct}%"></i></div>
          </div>
        `;
      }).join("");
    }

    function renderMealList(log) {
      document.getElementById("mealList").innerHTML = mealKeys.map((key) => {
        const meal = log.meals[key] || blankMeal();
        const kcal = meal.calories || macroCalories(meal);
        const filled = meal.carbs + meal.protein + meal.fat + meal.calories > 0;
        return `
          <button class="meal-row" type="button" onclick="openMeal('${key}')">
            <span>
              <h3>${mealLabels[key]}</h3>
              <p>${filled ? `碳 ${round(meal.carbs)}g · 蛋 ${round(meal.protein)}g · 脂 ${round(meal.fat)}g` : "还没记录"}</p>
            </span>
            <span class="meal-score">${round(kcal)} kcal</span>
          </button>
        `;
      }).join("");
    }

    function renderMealTabs() {
      document.querySelectorAll("[data-meal-tab]").forEach((button) => {
        button.classList.toggle("active", button.dataset.mealTab === activeMeal);
      });
    }

    function openMeal(key) {
      saveEditorToMeal();
      activeMeal = key;
      renderMealTabs();
      loadMealEditor();
      showScreen("log");
    }

    function renderTotals(log) {
      const items = [
        ["热量", `${round(log.calories)} kcal`],
        ["碳水", `${round(log.carbs)} g`],
        ["蛋白", `${round(log.protein)} g`],
        ["脂肪", `${round(log.fat)} g`]
      ];
      document.getElementById("todayTotals").innerHTML = items.map(([label, val]) => stat(label, val)).join("");
    }

    function renderAdvice(targets, log) {
      const gaps = {
        calories: Math.max(0, targets.calories - log.calories),
        carbs: Math.max(0, targets.carbs - log.carbs),
        protein: Math.max(0, targets.protein - log.protein),
        fat: Math.max(0, targets.fat - log.fat)
      };
      const tips = [];
      if (log.calories === 0) tips.push("今天先记录第一餐，任务分会马上动起来。");
      if (gaps.protein >= 20) tips.push(`蛋白还差 ${round(gaps.protein)}g，优先补鸡胸、鱼虾、瘦牛肉、蛋清、无糖酸奶或豆腐。`);
      if (gaps.carbs >= 40) tips.push(`碳水还差 ${round(gaps.carbs)}g，训练日前后可以补米饭、土豆、燕麦或全麦面包。`);
      if (gaps.fat >= 12) tips.push(`脂肪还差 ${round(gaps.fat)}g，少量坚果、全蛋、三文鱼或橄榄油更合适。`);
      if (!tips.length) tips.push("今天的碳蛋脂已经接近目标。剩下就看饱腹感、蔬菜、水和睡眠。");
      document.getElementById("adviceBox").innerHTML = tips.join("<br>");
    }

    function renderTrend() {
      const entries = Object.values(state.logs)
        .filter((log) => log.bodyWeight > 0)
        .sort((a, b) => a.date.localeCompare(b.date));
      const summary = document.getElementById("trendSummary");
      if (!entries.length) {
        summary.innerHTML = [stat("当前晨重", "暂无"), stat("7 日均重", "暂无"), stat("7 日变化", "暂无")].join("");
        document.getElementById("weightChart").innerHTML = `<text x="460" y="145" text-anchor="middle" class="chart-label">保存晨重后显示曲线</text>`;
        return;
      }
      const latest = entries[entries.length - 1];
      const last7 = entries.slice(-7);
      const prev7 = entries.slice(-14, -7);
      const lastAvg = avg(last7.map((item) => item.bodyWeight));
      const prevAvg = prev7.length ? avg(prev7.map((item) => item.bodyWeight)) : null;
      const change = prevAvg === null ? null : lastAvg - prevAvg;
      const gap = latest.bodyWeight - 78;
      summary.innerHTML = [
        stat("当前晨重", `${one(latest.bodyWeight)} kg`),
        stat("7 日均重", `${one(lastAvg)} kg`),
        stat("7 日均重变化", change === null ? "数据不足" : signed(change, "kg")),
        stat("距 78kg", gap <= 0 ? "已达成" : `${one(gap)} kg`),
        stat("趋势", trendText(change)),
        stat("连续记录", `${streakDays()} 天`)
      ].join("");
      renderWeightChart(entries);
    }

    function renderWeightChart(entries) {
      const svg = document.getElementById("weightChart");
      const w = 920;
      const h = 280;
      const pad = { left: 48, right: 18, top: 18, bottom: 34 };
      const avgPoints = entries.map((item, index) => ({
        date: item.date,
        bodyWeight: avg(entries.slice(Math.max(0, index - 6), index + 1).map((row) => row.bodyWeight))
      }));
      const values = entries.map((item) => item.bodyWeight).concat(avgPoints.map((item) => item.bodyWeight), [78]);
      const min = Math.floor((Math.min(...values) - 0.6) * 10) / 10;
      const max = Math.ceil((Math.max(...values) + 0.6) * 10) / 10;
      const x = (index) => entries.length === 1 ? w / 2 : pad.left + index * ((w - pad.left - pad.right) / (entries.length - 1));
      const y = (value) => pad.top + (max - value) * ((h - pad.top - pad.bottom) / (max - min || 1));
      const path = (points) => points.map((point, index) => `${index ? "L" : "M"} ${x(index).toFixed(1)} ${y(point.bodyWeight).toFixed(1)}`).join(" ");
      const ticks = [min, (min + max) / 2, max];
      const targetY = y(78);
      svg.innerHTML = `
        <rect x="0" y="0" width="${w}" height="${h}" fill="#fffdf8"></rect>
        ${ticks.map((tick) => `<line x1="${pad.left}" x2="${w - pad.right}" y1="${y(tick)}" y2="${y(tick)}" stroke="#ded8ca"></line><text x="10" y="${y(tick) + 4}" class="chart-label">${one(tick)}kg</text>`).join("")}
        <line x1="${pad.left}" x2="${w - pad.right}" y1="${targetY}" y2="${targetY}" stroke="#8f978c" stroke-dasharray="5 5"></line>
        <text x="${w - pad.right - 58}" y="${targetY - 7}" class="chart-label">78kg</text>
        <path d="${path(entries)}" fill="none" stroke="#2f6f4e" stroke-width="3"></path>
        <path d="${path(avgPoints)}" fill="none" stroke="#d88a3d" stroke-width="3"></path>
        ${entries.map((item, index) => `<circle cx="${x(index)}" cy="${y(item.bodyWeight)}" r="4" fill="#2f6f4e"></circle>`).join("")}
        <text x="${pad.left}" y="${h - 10}" class="chart-label">${entries[0].date}</text>
        <text x="${w - pad.right}" y="${h - 10}" text-anchor="end" class="chart-label">${entries[entries.length - 1].date}</text>
      `;
    }

    function renderHistory() {
      const entries = Object.values(state.logs).sort((a, b) => b.date.localeCompare(a.date));
      const history = document.getElementById("history");
      if (!entries.length) {
        history.innerHTML = '<div class="empty">还没有历史记录。保存今天后会显示在这里。</div>';
        return;
      }
      history.innerHTML = entries.map((log) => {
        const score = scoreLog(log, calculateTargets(readProfile())).score;
        return `
          <div class="history-item">
            <div>
              <strong>${log.date} · ${score}分</strong>
              <p>${log.bodyWeight ? `晨重 ${one(log.bodyWeight)}kg · ` : ""}热量 ${round(log.calories)} kcal · 碳 ${round(log.carbs)}g · 蛋 ${round(log.protein)}g · 脂 ${round(log.fat)}g</p>
              <p>${mealSummary(log)}</p>
            </div>
            <button class="btn secondary" type="button" onclick="loadHistory('${log.date}')">载入</button>
          </div>
        `;
      }).join("");
    }

    function loadHistory(date) {
      hydrateLog(date);
      render();
      showScreen("log");
    }

    function mealSummary(log) {
      const meals = log.meals || legacyMeals(log);
      return mealKeys.map((key) => {
        const meal = meals[key] || blankMeal();
        return `${mealLabels[key]} 碳${round(meal.carbs)} 蛋${round(meal.protein)} 脂${round(meal.fat)}`;
      }).join(" · ");
    }

    function scoreLog(log, targets) {
      let score = 0;
      const mealsDone = mealKeys.filter((key) => {
        const meal = log.meals?.[key] || blankMeal();
        return meal.calories + meal.carbs + meal.protein + meal.fat > 0;
      }).length;
      score += mealsDone * 10;
      if (log.bodyWeight > 0) score += 15;
      score += rangeScore(log.calories, targets.calories, 30);
      score += rangeScore(log.protein, targets.protein, 15);
      score += rangeScore(log.carbs, targets.carbs, 10);
      score += rangeScore(log.fat, targets.fat, 10);
      score = Math.min(100, Math.round(score));
      return {
        score,
        title: score >= 85 ? "今天很稳" : score >= 60 ? "任务进行中" : "先完成一餐"
      };
    }

    function rangeScore(value, target, points) {
      if (!target || !value) return 0;
      const ratio = value / target;
      if (ratio >= 0.9 && ratio <= 1.08) return points;
      if (ratio >= 0.75 && ratio <= 1.18) return Math.round(points * 0.7);
      if (ratio >= 0.55 && ratio <= 1.3) return Math.round(points * 0.4);
      return 0;
    }

    function streakDays() {
      let streak = 0;
      const cursor = new Date(todayISO + "T00:00:00");
      while (true) {
        const date = cursor.toISOString().slice(0, 10);
        const log = state.logs[date];
        if (!log || (log.calories <= 0 && !log.bodyWeight)) break;
        streak += 1;
        cursor.setDate(cursor.getDate() - 1);
      }
      return streak;
    }

    function calculateTargets(profile) {
      const sexOffset = profile.sex === "male" ? 5 : -161;
      const bmr = 10 * profile.weight + 6.25 * profile.height - 5 * profile.age + sexOffset;
      const maintenance = bmr * Number(profile.activity);
      const goalFactor = { loss: 0.82, "slow-loss": 0.9, maintain: 1, gain: 1.08 }[profile.goal] || 0.9;
      const calories = Math.max(1200, maintenance * goalFactor);
      if (profile.macroMode === "532") {
        return { bmr, maintenance, calories, carbs: calories * 0.5 / 4, protein: calories * 0.3 / 4, fat: calories * 0.2 / 9 };
      }
      const protein = profile.weight * profile.proteinRate;
      const fat = profile.weight * profile.fatRate;
      const carbs = Math.max(0, (calories - protein * 4 - fat * 9) / 4);
      return { bmr, maintenance, calories, carbs, protein, fat };
    }

    function macroCalories(meal) {
      return meal.carbs * 4 + meal.protein * 4 + meal.fat * 9;
    }

    function stat(label, value) {
      return `<div class="flat-card stat"><span>${label}</span><strong>${value}</strong></div>`;
    }

    function value(id) {
      return document.getElementById(id).value;
    }

    function num(id) {
      return Number(document.getElementById(id).value) || 0;
    }

    function round(value) {
      return Math.round(Number(value) || 0);
    }

    function one(value) {
      return (Number(value) || 0).toFixed(1);
    }

    function avg(values) {
      return values.reduce((sum, value) => sum + value, 0) / values.length;
    }

    function signed(value, unit) {
      const prefix = value > 0 ? "+" : "";
      return `${prefix}${one(value)} ${unit}`;
    }

    function trendText(change) {
      if (change === null) return "先记录 14 天";
      if (change <= -0.7) return "下降偏快";
      if (change <= -0.2) return "节奏很好";
      if (change < 0.2) return "基本平台";
      return "可能回升";
    }

    function formatDate(date) {
      const d = new Date(date + "T00:00:00");
      return `${d.getMonth() + 1}月${d.getDate()}日`;
    }

    function isOldExampleProfile(profile) {
      return profile.sex === "female" && Number(profile.age) === 28 && Number(profile.height) === 165 && Number(profile.weight) === 65;
    }

    function toast(message) {
      const el = document.getElementById("toast");
      el.textContent = message;
      el.classList.add("show");
      clearTimeout(toast.timer);
      toast.timer = setTimeout(() => el.classList.remove("show"), 2200);
    }
  </script>
</body>
</html>
